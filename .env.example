# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=lol_esport
PGUSER=postgres
PGPASSWORD=changeme

# Leaguepedia / Fandom credentials (OPTIONAL).
# Anonymous access works for reading Cargo data. Only set these if you hit
# rate limits and want a higher quota with a bot account.
# Create a bot password at https://lol.fandom.com/wiki/Special:BotPasswords
# USERNAME must be "YourFandomName@botlabel"; PASSWORD is the generated secret.
LEAGUEPEDIA_USERNAME=
LEAGUEPEDIA_PASSWORD=
